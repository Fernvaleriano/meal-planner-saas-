# =============================================================================
# Ziquecoach — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# On Netlify, set these in Site Settings > Environment Variables.
# =============================================================================

# --- Supabase (Required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Stripe (Required for payments) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BRANDED=price_...

# --- AI / LLM APIs ---
ANTHROPIC_API_KEY=sk-ant-...          # Required — meal plan generation, food analysis, coaching AI
OPENAI_API_KEY=sk-...                 # Required — workout generation, diary AI
GEMINI_API_KEY=...                    # Optional — image style questions fallback

# --- Image / Media ---
REPLICATE_API_TOKEN=r8_...            # Optional — AI meal images

# --- Food / Nutrition APIs ---
EDAMAM_APP_ID=...                     # Optional — nutrition validation
EDAMAM_API_KEY=...                    # Optional — nutrition validation
SPOONACULAR_API_KEY=...               # Optional — recipe search

# --- Email (pick ONE provider) ---
# Option 1: Resend (recommended)
RESEND_API_KEY=re_...
# Option 2: SendGrid
# SENDGRID_API_KEY=SG...
# Option 3: Mailgun
# MAILGUN_API_KEY=...
# MAILGUN_DOMAIN=mg.yourdomain.com

EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Ziquecoach
ADMIN_EMAIL=contact@yourdomain.com

# --- Notifications ---
FORM_NOTIFICATION_EMAIL=your-email@example.com

# --- App URL ---
# Netlify sets this automatically. Only set manually for local development.
# URL=http://localhost:8888
# SITE_URL=http://localhost:8888

# --- Supabase (client-side, used in legacy HTML pages) ---
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Error monitoring (Sentry) ---
# DSN from your Sentry project. Leave unset on local/dev — initSentry()
# no-ops without it. Must be set in Netlify env vars for the production
# build. The VITE_ prefix exposes it to the React client at build time.
VITE_SENTRY_DSN=https://...@...ingest.sentry.io/...
