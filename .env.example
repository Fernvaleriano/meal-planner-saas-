# =============================================================================
# Meal Planner SaaS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For Netlify deployment, set these in: Site Settings > Environment Variables
# =============================================================================

# --- Supabase (Required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Stripe (Required for billing) ---
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Price IDs (set in Stripe Dashboard > Products)
STRIPE_PRICE_STARTER=price_starter_monthly
STRIPE_PRICE_BASIC=price_basic_monthly
STRIPE_PRICE_GROWTH=price_growth_monthly
STRIPE_PRICE_PROFESSIONAL=price_professional_monthly
STRIPE_PRICE_BRANDED=price_branded_monthly

# --- AI Services ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-google-gemini-api-key

# --- Food / Nutrition APIs ---
EDAMAM_APP_ID=your-edamam-app-id
EDAMAM_API_KEY=your-edamam-api-key
SPOONACULAR_API_KEY=your-spoonacular-api-key

# --- Image Generation ---
REPLICATE_API_TOKEN=your-replicate-api-token

# --- Email (at least one provider required) ---
# Resend (recommended)
RESEND_API_KEY=re_your-resend-api-key

# SendGrid (alternative)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Mailgun (alternative)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com

# Email sender settings
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App Name

# --- Notification Recipients ---
ADMIN_EMAIL=admin@yourdomain.com
FORM_NOTIFICATION_EMAIL=forms@yourdomain.com
FITFORSHIFT_NOTIFICATION_EMAIL=notifications@yourdomain.com

# --- Application ---
URL=https://yourdomain.com

# --- Frontend (Vite - prefix with VITE_) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- CORS (optional - defaults to * if not set) ---
# Set to your domain in production for tighter security
CORS_ALLOWED_ORIGIN=https://yourdomain.com
